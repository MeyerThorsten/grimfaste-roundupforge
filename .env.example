DATABASE_URL="file:./dev.db"

# ── Scraper API Keys ─────────────────────────────────────────────
# Configure one or more. When multiple are set, requests are distributed
# across all of them (round-robin with failover) for maximum throughput.

# ScrapeOwl — https://scrapeowl.com (1M free credits)
SCRAPEOWL_API_KEY=your_key_here

# ScraperAPI — https://www.scraperapi.com (5,000 free credits/month)
# SCRAPERAPI_API_KEY=your_key_here

# ScrapingBee — https://www.scrapingbee.com (1,000 free credits)
# SCRAPINGBEE_API_KEY=your_key_here

# ZenRows — https://www.zenrows.com (1,000 free credits)
# ZENROWS_API_KEY=your_key_here

# ── Google Sheets Integration ────────────────────────────────────
# Service Account JSON for automated in-app sync:
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Default spreadsheet ID:
# GOOGLE_SHEET_ID=your_spreadsheet_id_here
